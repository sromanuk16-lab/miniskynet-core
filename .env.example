# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL_CHEAP=openai/gpt-4o-mini
OPENROUTER_MODEL_CODING=openai/gpt-4o-mini

# Cost guard. Prices are rough fallback values; adjust to the model you choose.
MAX_DAILY_COST_USD=0.50
MAX_CYCLES_PER_DAY=20
CHEAP_INPUT_COST_PER_1M=0.15
CHEAP_OUTPUT_COST_PER_1M=0.60
CODING_INPUT_COST_PER_1M=0.15
CODING_OUTPUT_COST_PER_1M=0.60
MAX_INPUT_CHARS=12000
MAX_OUTPUT_TOKENS=900

# Alive loop
ALIVE_INTERVAL_SECONDS=900
ALIVE_MAX_STEPS_PER_TICK=1
